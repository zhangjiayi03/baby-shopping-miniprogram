/* pages/mine/mine.wxss */
.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 120rpx;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 25rpx;
}

.avatar-emoji {
  font-size: 50rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.user-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 统计卡片 */
.stats-card {
  margin: 30rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.stat-row {
  display: flex;
}

.stat-box {
  flex: 1;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999999;
}

.stat-divider {
  width: 1rpx;
  background: #F0F0F0;
  margin: 0 20rpx;
}

.stat-highlight {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F5F5F5;
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.highlight-label {
  font-size: 24rpx;
  color: #999999;
}

.highlight-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF6B6B;
}

.highlight-product {
  flex: 1;
  font-size: 26rpx;
  color: #666666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 预算卡片 */
.budget-card {
  margin: 0 30rpx 30rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.budget-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.budget-title {
  font-size: 26rpx;
  color: #666666;
}

.budget-edit {
  font-size: 24rpx;
  color: #FF6B6B;
}

.budget-amount {
  font-size: 48rpx;
  font-weight: 700;
  color: #333333;
}

/* 菜单 */
.menu-section {
  margin: 0 30rpx 30rpx;
}

.menu-title {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 15rpx;
  padding-left: 10rpx;
}

.menu-list {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon {
  font-size: 36rpx;
}

.menu-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.menu-title-text {
  font-size: 28rpx;
  color: #333333;
}

.menu-desc {
  font-size: 22rpx;
  color: #999999;
}

.menu-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
}

/* 危险操作 */
.danger-section {
  margin: 60rpx 30rpx 30rpx;
}

.danger-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 30rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.danger-icon {
  font-size: 32rpx;
}

.danger-text {
  font-size: 28rpx;
  color: #FF6B6B;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx;
  font-size: 24rpx;
  color: #CCCCCC;
}
