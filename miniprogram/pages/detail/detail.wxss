/* pages/detail/detail.wxss */
.container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 详情展示样式 */
.detail-view {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.image-section {
  width: 100%;
  height: 400rpx;
  background-color: #f0f0f0;
}

.order-image {
  width: 100%;
  height: 100%;
}

.info-section {
  padding: 30rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.value.price {
  font-size: 32rpx;
  color: #ff6b00;
  font-weight: bold;
}

/* 编辑表单样式 */
.edit-view {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.form-section {
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.form-picker {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.picker-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 按钮样式 */
.action-section {
  display: flex;
  gap: 20rpx;
  padding-top: 20rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
  padding: 0;
}

.btn::after {
  border: none;
}

.btn-edit {
  background-color: #1890ff;
  color: #fff;
}

.btn-delete {
  background-color: #ff4d4f;
  color: #fff;
}

.btn-save {
  background-color: #52c41a;
  color: #fff;
}

.btn-cancel {
  background-color: #f0f0f0;
  color: #666;
}
