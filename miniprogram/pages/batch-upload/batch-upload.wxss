/* pages/batch-upload/batch-upload.wxss */
.container {
  padding: 30rpx;
  padding-bottom: 200rpx;
}

/* 头部 */
.header {
  text-align: center;
  margin-bottom: 20rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #999;
}

/* 宝宝选择 */
.baby-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 12rpx;
}

.baby-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 20rpx;
}

.baby-picker {
  min-width: 200rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  color: #ff6b00;
  font-weight: bold;
}

.picker-value .arrow {
  font-size: 20rpx;
  margin-left: 10rpx;
  color: #999;
}

/* 上传区域 */
.upload-section {
  text-align: center;
  margin-bottom: 40rpx;
}

.upload-btn {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.upload-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.upload-text {
  color: #fff;
  font-size: 28rpx;
}

.upload-hint {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* 图片列表 */
.image-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.image-item {
  position: relative;
  width: 100%;
  height: 300rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  overflow: hidden;
}

.image-preview {
  width: 100%;
  height: 100%;
}

.image-index {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 24rpx;
  padding: 6rpx 12rpx;
  border-radius: 20rpx;
}

.image-delete {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(255, 59, 48, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

.image-status {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.7);
  padding: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.status-text {
  color: #fff;
  font-size: 22rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 26rpx;
}

/* 操作按钮区 */
.action-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  padding: 0;
}

.action-btn.preview {
  background: #667eea;
  color: #fff;
}

.action-btn.clear {
  background: #f5f5f5;
  color: #666;
}

.action-btn.start {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.action-btn[disabled] {
  background: #ccc;
  color: #999;
}

/* 识别结果区 */
.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.result-count {
  font-size: 26rpx;
  color: #667eea;
}

.result-list {
  margin-bottom: 30rpx;
}

.result-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.result-item.success {
  border-left: 6rpx solid #52c41a;
}

.result-item.processing {
  border-left: 6rpx solid #1890ff;
}

.result-item.error {
  border-left: 6rpx solid #ff4d4f;
}

.result-status {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.status-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.status-text {
  font-size: 28rpx;
  font-weight: bold;
}

.result-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.product-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.result-error {
  padding: 16rpx;
  background: #fff2f0;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.error-text {
  font-size: 26rpx;
  color: #ff4d4f;
}

.result-actions {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
  align-items: center;
}

.edit-btn,
.save-btn {
  display: inline-block;
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  border-radius: 20rpx;
  border: none;
}

.edit-btn {
  background: #f0f0f0;
  color: #666;
}

.save-btn {
  background: #667eea;
  color: #fff;
}

.save-all-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(82, 196, 26, 0.3);
  padding: 0;
}
