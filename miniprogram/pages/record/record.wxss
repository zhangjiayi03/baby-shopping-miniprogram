/* pages/record/record.wxss */
.container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 上传区域 */
.upload-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.upload-actions {
  display: flex;
  gap: 20rpx;
}

.upload-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 180rpx;
  border: 2rpx dashed #1890ff;
  border-radius: 12rpx;
  background-color: #f0f8ff;
}

.upload-btn.batch-btn {
  border-color: #667eea;
  background-color: #f0f4ff;
}

.upload-icon {
  font-size: 60rpx;
  line-height: 1;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 26rpx;
  color: #1890ff;
}

.batch-btn .upload-text {
  color: #667eea;
}

.upload-icon {
  font-size: 80rpx;
  color: #1890ff;
  line-height: 1;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #1890ff;
}

.preview-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 30rpx;
}

.preview-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background-color: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
}

/* 识别结果区域 */
.result-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.result-card {
  border: 1rpx solid #f0f0f0;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #f9f9f9;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.edit-btn {
  font-size: 28rpx;
  color: #1890ff;
}

.card-body {
  padding: 30rpx;
}

.info-row {
  display: flex;
  margin-bottom: 20rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  width: 140rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.info-value.price {
  color: #ff6b00;
  font-weight: bold;
  font-size: 32rpx;
}

/* 操作按钮 */
.action-btns {
  display: flex;
  gap: 20rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
}

.btn::after {
  border: none;
}

.btn-save {
  background-color: #52c41a;
  color: #fff;
}

.btn-retry {
  background-color: #f0f0f0;
  color: #666;
}
