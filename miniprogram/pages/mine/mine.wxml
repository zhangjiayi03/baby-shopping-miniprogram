<!--pages/mine/mine.wxml-->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="avatar-section">
      <view class="avatar">👶</view>
      <view class="user-info">
        <text class="nickname">{{userInfo.nickname || '萌宝账本'}}</text>
        <text class="desc">已记录 {{totalDays}} 天 · {{totalRecords}} 笔订单</text>
      </view>
    </view>
    <view class="total-spent">
      <text class="label">累计消费</text>
      <text class="amount">¥{{totalSpentDisplay}}</text>
    </view>
  </view>
  
  <!-- 宝宝信息 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">👶 宝宝信息</text>
      <text class="section-action" bindtap="addBaby">+ 添加</text>
    </view>
    
    <!-- 宝宝列表 -->
    <view wx:if="{{babies.length > 0}}" class="baby-list">
      <view class="baby-card" wx:for="{{babies}}" wx:key="_id">
        <view class="baby-avatar">{{item.gender === 'female' ? '👧' : '👦'}}</view>
        <view class="baby-details">
          <view class="baby-name">{{item.nickname}}</view>
          <view class="baby-meta">
            <text wx:if="{{item.birthDate}}">生日: {{item.birthDate}}</text>
            <text wx:if="{{item.ageMonths !== null}}"> · {{item.ageMonths}}个月</text>
          </view>
        </view>
        <view class="baby-actions">
          <text class="action-btn" bindtap="editBaby" data-index="{{index}}">编辑</text>
          <text class="action-btn delete" bindtap="deleteBaby" data-index="{{index}}">删除</text>
        </view>
      </view>
    </view>
    
    <!-- 空状态 -->
    <view wx:else class="empty-baby">
      <text class="empty-icon">👶</text>
      <text class="empty-text">还没有添加宝宝信息</text>
      <text class="empty-hint" bindtap="addBaby">点击右上角"添加"按钮</text>
    </view>
  </view>
  
  <!-- 预算管理 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">💰 预算管理</text>
      <text class="section-action" bindtap="editBudget">设置</text>
    </view>
    <view class="budget-info">
      <view class="budget-item">
        <text class="budget-label">月度预算</text>
        <text class="budget-value">¥{{monthlyBudget}}</text>
      </view>
      <view class="budget-item">
        <text class="budget-label">本月已花</text>
        <text class="budget-value {{spentClass}}">¥{{spentThisMonthDisplay}}</text>
      </view>
      <view class="budget-item">
        <text class="budget-label">剩余预算</text>
        <text class="budget-value">¥{{budgetRemaining}}</text>
      </view>
      <view class="budget-progress">
        <view class="progress-bar" style="width: {{budgetPercent}}%"></view>
      </view>
      <view class="budget-tip {{budgetTipClass}}">{{budgetTip}}</view>
    </view>
  </view>
  
  <!-- 功能菜单 -->
  <view class="section">
    <view class="menu-list">
      <view class="menu-item" bindtap="exportData">
        <text class="menu-icon">📤</text>
        <text class="menu-text">导出账单</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="clearCache">
        <text class="menu-icon">🗑️</text>
        <text class="menu-text">清除缓存</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="feedback">
        <text class="menu-icon">💬</text>
        <text class="menu-text">意见反馈</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>
  
  <!-- 关于我们 -->
  <view class="section">
    <view class="menu-list">
      <view class="menu-item" bindtap="aboutUs">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于我们</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="checkUpdate">
        <text class="menu-icon">🔄</text>
        <text class="menu-text">检查更新</text>
        <text class="menu-badge" wx:if="{{hasUpdate}}">NEW</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>
  
  <!-- 版本信息 -->
  <view class="version-info">
    <text>Version {{version}}</text>
    <text class="copyright">© 2026 萌宝账本</text>
  </view>
  
  <!-- 编辑宝宝弹窗 -->
  <view class="dialog-mask" wx:if="{{showBabyDialog}}" bindtap="hideBabyDialog">
    <view class="dialog" catchtap="true">
      <view class="dialog-title">{{babyForm.id ? '编辑宝宝' : '添加宝宝'}}</view>
      <view class="dialog-content">
        <view class="form-item">
          <text class="form-label">昵称</text>
          <input class="form-input" value="{{babyForm.nickname}}" bindinput="onNicknameInput" placeholder="请输入宝宝昵称" />
        </view>
        <view class="form-item">
          <text class="form-label">生日</text>
          <picker class="form-picker" mode="date" value="{{babyForm.birthDate}}" bindchange="onBirthDateChange">
            <view class="picker-value">{{babyForm.birthDate || '选择日期'}}</view>
          </picker>
        </view>
        <view class="form-item">
          <text class="form-label">性别</text>
          <picker class="form-picker" mode="selector" range="{{['男孩', '女孩']}}" value="{{babyForm.gender === 'female' ? 1 : 0}}" bindchange="onGenderChange">
            <view class="picker-value">{{babyForm.gender === 'female' ? '女孩' : '男孩'}}</view>
          </picker>
        </view>
      </view>
      <view class="dialog-footer">
        <button class="dialog-cancel" bindtap="hideBabyDialog">取消</button>
        <button class="dialog-confirm" bindtap="saveBabyInfo">保存</button>
      </view>
    </view>
  </view>
  
  <!-- 预算设置弹窗 -->
  <view class="dialog-mask" wx:if="{{showBudgetDialog}}" bindtap="hideBudgetDialog">
    <view class="dialog" catchtap="true">
      <view class="dialog-title">设置月度预算</view>
      <view class="dialog-content">
        <view class="form-item">
          <text class="form-label">预算金额（元）</text>
          <input class="form-input" type="number" value="{{budgetForm.amount}}" bindinput="onBudgetInput" placeholder="请输入预算金额" />
        </view>
      </view>
      <view class="dialog-footer">
        <button class="dialog-cancel" bindtap="hideBudgetDialog">取消</button>
        <button class="dialog-confirm" bindtap="saveBudget">保存</button>
      </view>
    </view>
  </view>
</view>
