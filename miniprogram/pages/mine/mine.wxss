/* pages/mine/mine.wxss */
.container {
  padding: 20rpx;
  background: #f5f6f7;
  min-height: 100vh;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  color: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.avatar-section {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.nickname {
  font-size: 32rpx;
  font-weight: bold;
}

.desc {
  font-size: 24rpx;
  opacity: 0.8;
}

.total-spent {
  text-align: right;
}

.total-spent .label {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
  margin-bottom: 8rpx;
}

.total-spent .amount {
  font-size: 40rpx;
  font-weight: bold;
}

/* 区块 */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.section-action {
  font-size: 26rpx;
  color: #667eea;
}

/* 宝宝列表 */
.baby-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.baby-card {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.baby-avatar {
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.baby-details {
  flex: 1;
}

.baby-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.baby-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.baby-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  background: #667eea;
  color: #fff;
}

.action-btn.delete {
  background: #ff4d4f;
}

.empty-baby {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  color: #999;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #667eea;
  margin-top: 8rpx;
}

/* 宝宝信息 */
.baby-info {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.baby-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.baby-item:last-child {
  border-bottom: none;
}

.baby-label {
  font-size: 26rpx;
  color: #666;
}

.baby-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* 预算信息 */
.budget-info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.budget-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.budget-label {
  font-size: 26rpx;
  color: #666;
}

.budget-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.budget-value.warning {
  color: #ff9800;
}

.budget-value.danger {
  color: #f44336;
}

.budget-progress {
  width: 100%;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-top: 8rpx;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 8rpx;
  transition: width 0.3s;
}

.budget-tip {
  font-size: 24rpx;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  margin-top: 8rpx;
}

.budget-tip.normal {
  background: #e8f5e9;
  color: #4caf50;
}

.budget-tip.warning {
  background: #fff3e0;
  color: #ff9800;
}

.budget-tip.danger {
  background: #ffebee;
  color: #f44336;
}

/* 菜单列表 */
.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.menu-badge {
  background: #f44336;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 24rpx;
}

.copyright {
  display: block;
  margin-top: 8rpx;
}

/* 弹窗 */
.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.dialog {
  width: 600rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  animation: slideUp 0.3s;
}

@keyframes slideUp {
  from {
    transform: translateY(100rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.dialog-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dialog-content {
  padding: 30rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
}

.form-input {
  background: #f5f6f7;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

.picker-value {
  background: #f5f6f7;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
}

.dialog-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.dialog-cancel,
.dialog-confirm {
  flex: 1;
  padding: 24rpx;
  font-size: 28rpx;
  border: none;
}

.dialog-cancel {
  background: #f5f6f7;
  color: #666;
}

.dialog-confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}
