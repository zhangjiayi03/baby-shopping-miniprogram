/* pages/stats/stats.wxss */
.container {
  padding: 20rpx;
  background: #f5f6f7;
  min-height: 100vh;
}

/* 概览卡片 */
.stats-overview {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.overview-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.overview-card.today {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.overview-card.month {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
}

.card-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 10rpx;
}

.card-value {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.card-detail {
  font-size: 22rpx;
  opacity: 0.8;
}

/* 统计区块 */
.stats-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

/* 柱状图 */
.chart-container {
  padding: 20rpx 0;
}

.bar-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 300rpx;
  padding: 20rpx 10rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  margin: 0 8rpx;
}

.bar-value {
  width: 40rpx;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  border-radius: 8rpx 8rpx 0 0;
  min-height: 20rpx;
  transition: all 0.3s;
}

.bar-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
}

.bar-amount {
  font-size: 20rpx;
  color: #667eea;
  font-weight: bold;
  margin-top: 6rpx;
}

/* 分类列表 */
.category-list {
  margin-top: 10rpx;
}

.category-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.category-item:last-child {
  border-bottom: none;
}

.category-info {
  display: flex;
  align-items: center;
  width: 140rpx;
}

.category-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.category-name {
  font-size: 26rpx;
  color: #333;
}

.category-detail {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: auto;
  margin-right: 30rpx;
}

.category-amount {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.category-percent {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.category-bar {
  width: 200rpx;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.category-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s;
}

/* 平台列表 */
.platform-list {
  margin-top: 10rpx;
}

.platform-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.platform-item:last-child {
  border-bottom: none;
}

.platform-name {
  font-size: 26rpx;
  color: #333;
}

.platform-detail {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.platform-amount {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.platform-percent {
  font-size: 22rpx;
  color: #999;
  background: #f5f6f7;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.start-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.loading-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}
