<!--components/stats-card/stats-card.wxml-->
<view class="stats-card">
  <view class="card-header">
    <text class="card-icon">💰</text>
    <text class="card-title">今日花费</text>
  </view>
  
  <view class="stats-content">
    <view class="today-amount">¥{{todaySpent}}</view>
    
    <view class="comparison">
      <view class="change-tag {{changeClass}}">
        <text class="change-icon">{{changeIcon}}</text>
        <text class="change-value">{{changePercent}}%</text>
      </view>
      <text class="comparison-text">较昨日</text>
      <text class="order-count">({{orderCount}}笔)</text>
    </view>
  </view>
</view>
