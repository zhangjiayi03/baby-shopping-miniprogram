/* components/budget-card/budget-card.wxss */
.budget-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 0 30rpx 20rpx;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 25rpx;
}

.card-icon {
  font-size: 36rpx;
  margin-right: 15rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
}

.budget-info {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.budget-amount {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
}

.amount-label {
  font-size: 26rpx;
  opacity: 0.9;
  margin-right: 10rpx;
}

.amount-value {
  font-size: 40rpx;
  font-weight: bold;
  margin-right: 15rpx;
}

.amount-value.budget {
  font-size: 32rpx;
  opacity: 0.9;
}

.amount-divider {
  font-size: 28rpx;
  margin: 0 10rpx;
  opacity: 0.7;
}

.progress-bar {
  height: 12rpx;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #fff;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.budget-remaining {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.remaining-label {
  font-size: 26rpx;
  opacity: 0.9;
}

.remaining-value {
  font-size: 36rpx;
  font-weight: bold;
}

.percentage-tag {
  background-color: rgba(255, 255, 255, 0.3);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}
